[
  {
    "name": "fetch",
    "transport": "http",
    "access": "admin",
    "url": "https://mcp.example.com/mcp",
    "headers": { "Authorization": "Bearer YOUR_TOKEN" }
  },
  {
    "name": "filesystem",
    "transport": "sse",
    "access": "admin",
    "url": "https://mcp.example.com/sse"
  },
  {
    "name": "git",
    "transport": "stdio",
    "access": "admin",
    "command": "uvx",
    "args": ["mcp-server-git", "--repository", "/path/to/repo"],
    "env": {}
  }
]
