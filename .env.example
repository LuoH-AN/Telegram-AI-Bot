# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Discord Bot Token
# DISCORD_BOT_TOKEN=your_discord_bot_token_here
# DISCORD_COMMAND_PREFIX=!
# Discord API Base URL (optional, for reverse proxy)
# Example: https://your-proxy.example.com
# Also supports full API base: https://your-proxy.example.com/api/v10
# DISCORD_API_BASE=
# Discord Gateway Base URL (optional, WebSocket reverse proxy)
# Example: wss://your-proxy.example.com/gateway
# DISCORD_GATEWAY_BASE=
# Discord CDN Base URL (optional, media/file reverse proxy)
# Example: https://your-proxy.example.com/cdn
# DISCORD_CDN_BASE=
# Discord invite short link base (optional, only affects generated URLs)
# Example: https://your-proxy.example.com/invite
# DISCORD_INVITE_BASE=

# Telegram API Base URL (optional, for reverse proxy in China)
# Example: https://your-proxy.example.com/bot
# TELEGRAM_API_BASE=
# Telegram send rate limiting (optional)
# TELEGRAM_SEND_GLOBAL_RATE=25
# TELEGRAM_SEND_GLOBAL_PERIOD=1
# TELEGRAM_SEND_PER_CHAT_RATE=1
# TELEGRAM_SEND_PER_CHAT_PERIOD=1
# TELEGRAM_SEND_PER_CHAT_EDIT_RATE=3
# TELEGRAM_SEND_PER_CHAT_EDIT_PERIOD=1
# TELEGRAM_SEND_MAX_RETRIES=8
# TELEGRAM_SEND_RETRY_JITTER=0.4
# TELEGRAM_SEND_QUEUE_WARN_THRESHOLD=100
# STREAM_UPDATE_INTERVAL=0.35
# STREAM_MIN_UPDATE_CHARS=24
# STREAM_FORCE_UPDATE_INTERVAL=1.2

# Health check server port (for deployment platforms)
# PORT=8080

# PostgreSQL Database URL
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.7
# Optional reasoning effort (chat.completions): none|minimal|low|medium|high|xhigh
# OPENAI_REASONING_EFFORT=medium
OPENAI_SYSTEM_PROMPT=You are a helpful assistant.

# Tool defaults (optional)
# ENABLED_TOOLS=memory,search,fetch,wikipedia,tts
# CRON_ENABLED_TOOLS=search,fetch,wikipedia,tts
# Browser defaults (optional)
# BROWSER_HEADLESS=0
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium
# Auto-start browser runtimes at process boot (for playwright/browser_agent/crawl4ai)
# BROWSER_AUTO_START=1
# BROWSER_AUTO_START_BACKGROUND=1
# BROWSER_AUTO_START_CRAWL4AI=1

# Hugging Face Dataset persistence (optional, for ephemeral runtimes)
# Set these 3 values to persist browser login state + shell workspace snapshots.
# HF_DATASET_USERNAME=your_hf_username
# HF_DATASET_TOKEN=hf_xxx
# HF_DATASET_NAME=your_dataset_name
# Encryption key is REQUIRED when HF dataset persistence is enabled.
# Any long random string works; all persisted blobs are AES-GCM encrypted.
# HF_DATASET_ENCRYPTION_KEY=change_this_to_a_long_random_secret
# Optional advanced settings
# HF_DATASET_BRANCH=main
# HF_DATASET_PREFIX=gemen_state
# HF_DATASET_ENABLED=1
# Shell snapshot limits (bytes). 0 means unlimited.
# SHELL_HF_SNAPSHOT_MAX_BYTES=0
# SHELL_HF_SNAPSHOT_MAX_FILE_BYTES=0
# SHELL_HF_SYNC_INTERVAL_SECONDS=8
# SHELL_HF_MAX_FILES=0

# Web Search & Fetch (optional)
# BROWSERLESS_API_TOKEN=your_browserless_api_token_here
# OLLAMA_API_KEY=your_ollama_api_key_here
# JINA_API_KEY=your_jina_api_key_here

# TTS defaults (optional)
# TTS_VOICE=zh-CN-XiaoxiaoMultilingualNeural
# TTS_STYLE=general
# TTS_ENDPOINT=southeastasia
# TTS_OUTPUT_FORMAT=ogg-24khz-16bit-mono-opus

# Embedding / Memory Vector Search (optional)
# Enables semantic memory: vector search for relevant memories instead of injecting all.
# If not set, memory system falls back to the original behavior (return all memories).
NVIDIA_API_KEY=your_nvidia_api_key_here
# EMBEDDING_BASE_URL=https://integrate.api.nvidia.com/v1
# EMBEDDING_MODEL=baai/bge-m3
# MEMORY_TOP_K=10
# MEMORY_SIMILARITY_THRESHOLD=0.35
# MEMORY_DEDUP_THRESHOLD=0.85
