# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Plugin System (optional)
# Directory where external plugins are installed (default: runtime/plugins).
# PLUGIN_DIR=runtime/plugins

# WeChat Bot (official Weixin bot protocol)
# Enable the standalone WeChat runtime.
# WECHAT_ENABLED=1
# Slash-style command prefix in WeChat direct messages.
# WECHAT_COMMAND_PREFIX=/
# Official bot type used during QR login.
# WECHAT_BOT_TYPE=3
# Local directory for WeChat login state / cursors / temp files.
# WECHAT_STATE_DIR=.wechat_state
# Optional fixed access token for QR helper links.
# If not set, the process will generate one and write it to .wechat_state/login_snapshot.json
# WECHAT_LOGIN_ACCESS_TOKEN=change_me
# WeChat group trigger behavior.
# When off, group chats only respond to commands or configured mentions.
# WECHAT_GROUP_REPLY_ALL=0
# Comma-separated aliases used to detect @ mentions in WeChat group text.
# WECHAT_GROUP_MENTION_ALIASES=AI,ai,Bot,bot,助手,机器人,Gemen,gemen

# OneBot/NapCat QQ Bot
# Enable the OneBot runtime for QQ via NapCat.
# ONEBOT_ENABLED=1
# NapCat WebSocket URL (default: ws://127.0.0.1:6099)
# ONEBOT_WS_URL=ws://127.0.0.1:6099
# NapCat HTTP URL (default: http://127.0.0.1:3000)
# ONEBOT_HTTP_URL=http://127.0.0.1:3000
# Access token (set in NapCat config panel)
# ONEBOT_ACCESS_TOKEN=
# Slash-style command prefix in QQ messages.
# QQ_COMMAND_PREFIX=/
# Local directory for OneBot state files.
# QQ_STATE_DIR=runtime/qq
# QQ group reply behavior (when off, only responds to commands/mentions).
# QQ_GROUP_REPLY_ALL=0
# Comma-separated aliases for @ mentions in QQ groups.
# QQ_GROUP_MENTION_ALIASES=AI,ai,Bot,bot,助手,机器人

# Telegram API Base URL (optional, for reverse proxy in China)
# Example: https://your-proxy.example.com/bot
# TELEGRAM_API_BASE=
# Telegram send rate limiting (optional)
# TELEGRAM_SEND_GLOBAL_RATE=25
# TELEGRAM_SEND_GLOBAL_PERIOD=1
# TELEGRAM_SEND_PER_CHAT_RATE=1
# TELEGRAM_SEND_PER_CHAT_PERIOD=1
# TELEGRAM_SEND_PER_CHAT_EDIT_RATE=3
# TELEGRAM_SEND_PER_CHAT_EDIT_PERIOD=1
# TELEGRAM_SEND_MAX_RETRIES=8
# TELEGRAM_SEND_RETRY_JITTER=0.4
# TELEGRAM_SEND_QUEUE_WARN_THRESHOLD=100
# STREAM_UPDATE_INTERVAL=0.35
# STREAM_MIN_UPDATE_CHARS=24
# STREAM_FORCE_UPDATE_INTERVAL=1.2

# Health check server port (for deployment platforms)
# PORT=8080

# PostgreSQL Database URL
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Optional: inject multiple environment variables via one text blob.
# `ENV_TEXT` is applied before runtime token checks in shell/python startup logic.
# Backward-compatible fallback: `ENV_CONTENT`
# Example:
# ENV_TEXT=TELEGRAM_BOT_TOKEN=xxx\nWECHAT_ENABLED=1

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.7
# Optional reasoning effort (chat.completions): none|minimal|low|medium|high|xhigh
# OPENAI_REASONING_EFFORT=medium
OPENAI_SYSTEM_PROMPT=You are a helpful assistant.

# Tool defaults (optional)
# ENABLED_TOOLS=memory,search,fetch,wikipedia,tts
# CRON_ENABLED_TOOLS=search,fetch,wikipedia,tts
# Browser defaults (optional)
# BROWSER_HEADLESS=0

# Hugging Face Dataset persistence (optional, for ephemeral runtimes)
# Set these 3 values to persist browser login state + shell workspace/runtime snapshots.
# HF_DATASET_USERNAME=your_hf_username
# HF_DATASET_TOKEN=hf_xxx
# HF_DATASET_NAME=your_dataset_name
# Encryption key is REQUIRED when HF dataset persistence is enabled.
# Any long random string works; all persisted blobs are AES-GCM encrypted.
# HF_DATASET_ENCRYPTION_KEY=change_this_to_a_long_random_secret
# Optional advanced settings
# HF_DATASET_BRANCH=main
# HF_DATASET_PREFIX=gemen_state
# HF_DATASET_ENABLED=1
# Shell snapshot limits (bytes). 0 means unlimited.
# SHELL_HF_SNAPSHOT_MAX_BYTES=0
# SHELL_HF_SNAPSHOT_MAX_FILE_BYTES=0
# Save after every command by default. Increase if you want fewer uploads.
# SHELL_HF_SYNC_INTERVAL_SECONDS=0
# SHELL_HF_MAX_FILES=0
# By default shell snapshots include the whole working directory.
# You can optionally skip dirs/suffixes here (comma-separated).
# SHELL_HF_SKIP_DIRS=
# SHELL_HF_SKIP_SUFFIXES=
# Extra user paths restored across restarts (comma-separated).
# SHELL_HF_PERSIST_PATHS=~/.local,~/.nvm,~/.npm,~/.yarn,~/.config/yarn,~/.cache/node/corepack,~/.pnpm-store

# Web Search & Fetch (optional)
# BROWSERLESS_API_TOKEN=your_browserless_api_token_here
# OLLAMA_API_KEY=your_ollama_api_key_here
# JINA_API_KEY=your_jina_api_key_here

# TTS defaults (optional)
# TTS_VOICE=zh-CN-XiaoxiaoMultilingualNeural
# TTS_STYLE=general
# TTS_ENDPOINT=southeastasia
# TTS_OUTPUT_FORMAT=ogg-24khz-16bit-mono-opus

# Embedding / Memory Vector Search (optional)
# Enables semantic memory: vector search for relevant memories instead of injecting all.
# If not set, memory system falls back to the original behavior (return all memories).
NVIDIA_API_KEY=your_nvidia_api_key_here
# EMBEDDING_BASE_URL=https://integrate.api.nvidia.com/v1
# EMBEDDING_MODEL=baai/bge-m3
# MEMORY_TOP_K=10
# MEMORY_SIMILARITY_THRESHOLD=0.35
# MEMORY_DEDUP_THRESHOLD=0.85
