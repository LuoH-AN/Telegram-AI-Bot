# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- Security: who may use high-risk (danger) tools like `terminal` -----------
# Danger tools are disabled for everyone unless their Telegram user id is listed
# here. Set at least your own id (get it from @userinfobot). Comma/semicolon separated.
# ADMIN_IDS=123456789,987654321
# OWNER_ID=123456789
# Directories `send_file source=path` may read from (comma/colon separated).
# Defaults to the repo root and /data. Sensitive files (.env, id_rsa, *.pem, ...)
# are always denied even inside a root.
# TOOL_FILE_ROOTS=/data,./runtime

# --- Public OpenAPI tool server ----------------------------------------------
# Required before /tools/search or /tools/terminal accepts requests.
# OPENAPI_TOOLS_TOKEN=replace-with-a-long-random-token
# Comma-separated browser origins. Empty disables browser CORS access.
# OPENAPI_TOOLS_CORS_ORIGINS=https://openwebui.example.com
# Terminal routes additionally require an admin Telegram id here.
# OPENAPI_TOOLS_USER_ID=123456789

# --- Memory: bound per-session conversation history --------------------------
# Oldest already-persisted messages past this count are dropped from memory
# (they remain in the DB and are reloaded on next read). 0 disables eviction.
# CONVERSATION_CACHE_CAP=500

# Plugin System (optional)
# Persistent directory where external plugins are installed (default: /data/plugins).
# PLUGIN_DIR=/data/plugins

# Telegram API Base URL (optional, for reverse proxy in China; do not include /bot)
# Example: https://api.telegram.bot.luoh.org
# TELEGRAM_API_BASE=
# Telegram Bot API 10.x features (optional)
# TELEGRAM_NATIVE_DRAFTS=1
# TELEGRAM_RICH_MESSAGES=1
# Telegram send rate limiting (optional)
# TELEGRAM_SEND_GLOBAL_RATE=25
# TELEGRAM_SEND_GLOBAL_PERIOD=1
# TELEGRAM_SEND_PER_CHAT_RATE=1
# TELEGRAM_SEND_PER_CHAT_PERIOD=1
# TELEGRAM_SEND_PER_CHAT_EDIT_RATE=3
# TELEGRAM_SEND_PER_CHAT_EDIT_PERIOD=1
# TELEGRAM_SEND_MAX_RETRIES=8
# TELEGRAM_SEND_RETRY_JITTER=0.4
# TELEGRAM_SEND_QUEUE_WARN_THRESHOLD=100
# STREAM_UPDATE_INTERVAL=0.35
# STREAM_MIN_UPDATE_CHARS=24
# STREAM_FORCE_UPDATE_INTERVAL=1.2

# Health check server port (for deployment platforms)
# PORT=8080

# PostgreSQL Database URL
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Optional: inject multiple environment variables via one text blob.
# `ENV_TEXT` is applied before runtime token checks in shell/python startup logic.
# Backward-compatible fallback: `ENV_CONTENT`
# Example:
# ENV_TEXT=TELEGRAM_BOT_TOKEN=xxx\nOPENAI_API_KEY=yyy

# Optional: persist terminal install commands on a mounted disk.
# If set to a directory, telegram_ai_bot_cli_bootstrap.txt is used inside it.
# CLI_BOOTSTRAP_PATH=/data/telegram_ai_bot_cli_bootstrap.txt
# Persistent terminal workers, logs, control sockets, and completion-event state.
# Defaults to /data/telegram_ai_bot/terminal when /data exists.
# TERMINAL_STATE_DIR=/data/telegram_ai_bot/terminal
# Optional direct override for the SQLite registry file.
# TERMINAL_STATE_DB=/data/telegram_ai_bot/terminal/sessions.sqlite3
# All terminal HOME files, dependencies, package-manager caches and temporary
# files are stored below this directory and therefore included in /data backup.
# No dependency directories (node_modules, virtualenvs, caches, hidden files)
# are excluded by the backup scanner.
# TERMINAL_PERSISTENT_ROOT=/data/telegram_ai_bot/terminal/filesystem
# The terminal's complete default workspace is also archived with no ignore
# rules, including .git, node_modules, virtualenvs, caches and hidden files.
# Defaults to this repository root; set only if terminal uses another workspace.
# BACKUP_TERMINAL_WORKSPACE=/root/Telegram-AI-Bot
# Every completed foreground/background terminal command requests a coalesced
# backup within about one second, including partial files from failed installers.
# This interval is only the fallback periodic snapshot.
# BACKUP_INTERVAL_SECONDS=600
# Launcher-managed /update and /restart preserve the live /data/workspace
# directly and do not overlay them with a possibly stale cold-start backup.

# Hot update source used when the runtime image does not include .git metadata.
# HOT_UPDATE_REPO_URL=https://github.com/LuoH-AN/Telegram-AI-Bot.git
# HOT_UPDATE_BRANCH=main

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.7
# Optional reasoning effort (chat.completions): none|minimal|low|medium|high|xhigh
# OPENAI_REASONING_EFFORT=medium
OPENAI_SYSTEM_PROMPT=You are a helpful assistant.
# DEFAULT_TIMEZONE=Asia/Shanghai

# Tool defaults (optional)
# ENABLED_TOOLS=memory,search,send_file
# Tool-call rounds have no fixed limit. They continue until the model finishes,
# the user cancels, or an existing request/tool timeout interrupts execution.
# Scheduled tasks currently run without tools.

# Exa web search (optional; required when `search` is enabled)
# Multiple keys are rotated automatically; EXA_API_KEY is also supported.
# EXA_API_KEYS=exa-key-1,exa-key-2
# EXA_ENDPOINT=https://api.exa.ai/search
# Exa mode: auto|fast|instant|deep-lite|deep|deep-reasoning
# EXA_SEARCH_TYPE=auto
# Filter unsafe results at the provider layer.
# EXA_MODERATION=false
# In-memory query cache.
# EXA_CACHE_TTL=300
# EXA_CACHE_MAX_ENTRIES=256

# Embedding / Memory Vector Search (optional)
# Enables semantic memory: vector search for relevant memories instead of injecting all.
# If not set, memory system falls back to the original behavior (return all memories).
NVIDIA_API_KEY=your_nvidia_api_key_here
# EMBEDDING_BASE_URL=https://integrate.api.nvidia.com/v1
# EMBEDDING_MODEL=baai/bge-m3
# MEMORY_TOP_K=10
# MEMORY_SIMILARITY_THRESHOLD=0.35
# MEMORY_DEDUP_THRESHOLD=0.85
